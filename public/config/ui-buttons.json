{
  "version": "1.2",
  "buttons": {
    "header-reset": {
      "label": "Сброс",
      "icon": "↺",
      "title": "Сбросить все параметры",
      "styles": {
        "borderColor": "var(--red)",
        "color": "var(--red)",
        "background": "rgba(255,118,117,0.1)"
      },
      "action": { "type": "call", "name": "resetAll" }
    },
    "collapse-all": {
      "label": "Свернуть",
      "title": "Свернуть все окна",
      "styles": {
        "borderColor": "var(--accent-k)",
        "color": "var(--accent-k)",
        "background": "rgba(0,212,255,0.08)"
      },
      "action": { "type": "call", "name": "toggleAllSections" }
    },
    "translate": {
      "label": "Перевести на EN",
      "icon": "🌐",
      "styles": {
        "minWidth": "auto",
        "padding": "6px 14px",
        "fontSize": ".82em"
      },
      "action": { "type": "call", "name": "translateScene" }
    },
    "enhance": {
      "label": "Улучшить AI",
      "icon": "✦",
      "styles": {
        "minWidth": "auto",
        "padding": "6px 14px",
        "fontSize": ".82em",
        "color": "var(--accent-k)",
        "borderColor": "rgba(0,212,255,0.3)"
      },
      "action": { "type": "call", "name": "enhancePrompt" }
    },
    "seed-random": {
      "label": "Random",
      "icon": "🎲",
      "styles": {
        "minWidth": "auto",
        "padding": "8px 12px",
        "fontSize": ".82em"
      }
    },
    "seed-clear": {
      "label": "",
      "icon": "✕",
      "styles": {
        "minWidth": "auto",
        "padding": "8px 12px",
        "fontSize": ".82em"
      }
    },
    "format-flat": {
      "label": "Flat (рекомендуется)",
      "attrs": { "data-format": "flat" },
      "action": { "type": "call", "name": "setPromptFormat", "args": ["flat"] }
    },
    "format-structured": {
      "label": "Structured",
      "attrs": { "data-format": "structured" },
      "action": { "type": "call", "name": "setPromptFormat", "args": ["structured"] }
    },
    "format-midjourney": {
      "label": "Midjourney",
      "attrs": { "data-format": "midjourney" },
      "action": { "type": "call", "name": "setPromptFormat", "args": ["midjourney"] }
    },
    "copy-prompt": {
      "label": "Копировать",
      "icon": "📋"
    },
    "compact": {
      "label": "Компакт",
      "icon": "⚡",
      "title": "Свести промпт к минимально нужному ядру"
    },
    "save": {
      "label": "Сохранить",
      "icon": "💾"
    },
    "reset": {
      "label": "Сброс",
      "icon": "🗑️"
    }
  }
}
